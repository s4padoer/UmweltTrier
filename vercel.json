{
  "version": 2,
  "functions": {
    "app.py": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "builds": [
    {
      "src": "src/umwelttrier/app/main.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12",
        "install": ["uv pip install -e ."]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/umwelttrier/app/main.py"
    }
  ],
  "rewrites": [
    {"source": "/assets/(.*)", "destination": "/src/umwelttrier/app/assets/$1"}
  ]
}
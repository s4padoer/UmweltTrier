{
  "version": 2,
  "buildCommand": "bash build.sh",
  "functions":{
      "src": "src/umwelttrier/app/main.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12"
      }
    },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/umwelttrier/app/main.py"
    }
  ]
}
{
  "version": 2,
  "installCommand": "bash build.sh",
  "builds": [
    {
      "src": "src/umwelttrier/app/main.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/umwelttrier/app/main.py"
    }
  ],
  "includeFiles": [
    "src/umwelttrier/app/assets/**"
  ]
}